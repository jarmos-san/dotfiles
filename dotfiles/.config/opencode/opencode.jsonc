{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "command": {
    "check": {
      "template": "Run all pre-commit checks on the codebase (linting, formatting, typechecking). Fix any issues found.",
      "description": "Run all pre-commit checks (lint, format, typecheck)"
    }
  },
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "formatter": false,
  "lsp": true,
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "grep *": "allow",
      "ls *": "allow", // Allow listing file/directory objects in the filesystem
      "rg *": "allow", // Allow invoking "ripgrep"
      "mkdir *": "allow", // Allow creating arbitrary directories
      "which *": "allow"
    },
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow"
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.6"
  ]
}
