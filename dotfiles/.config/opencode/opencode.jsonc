{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "formatter": {
    "gofmt": {
      "disabled": true
    },
    "golangci-lint": {
      "command": [
        "golangci-lint",
        "fmt"
      ],
      "extensions": [
        ".go"
      ]
    }
  },
  "lsp": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.6"
  ],
  "agent": { // Configurations for the default builtin agents
    "build": { // Configurations for the default "build" agent
      "permission": {
        "edit": "allow", // Allow editing for the "build" agent
        "bash": { // Fine-tuned permissions for running Bash commands for the "build" command
          "*": "ask", // Ask for executing arbitrary shell commands
          "rm *": "ask", // Ask to execute the "rm" command
          "grep *": "allow", // Allow executing the "grep" command
          "ls *": "allow", // Allow listing file/directory objects in the filesystem
          "rg *": "allow", // Allow invoking "ripgrep"
          "mkdir *": "allow", // Allow creating arbitrary directories
          "which *": "allow", // Allow executing the "which" command
          "echo *": "allow", // Allow print messages to STDOUT
          "go test *": "allow", // Allow running Go test suite
          "go build *": "allow", // Allow building the executable Go binary
          "golangci-lint *": "allow", // Allow running various Go linters
          "task lint *": "allow" // Allow running linting commands where possible
        }
      }
    },
    "plan": { // Configurations for the default "plan" agent
      "permission": {
        "read": "allow" // Allow reading files and contents of folders by default
      }
    }
  },
  "permission": { // Default and global permissions for ALL agents
    "bash": { // Global permissions for executing arbitrary Bash commands
      "*": "deny" // Disable executing arbitrary shell commands by agents
    }
  }
}
